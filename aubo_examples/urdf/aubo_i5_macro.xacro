<?xml version="1.0"?>
<!--
  Prefixed xacro macro for the Aubo i5 robot.
  Derived from aubo_description/urdf/aubo_i5.urdf.
  Meshes still reference the aubo_description package.

  Params:
    parent  - name of the parent link to attach the robot base to
    prefix  - string prepended to every link/joint name (e.g. "aubo_")
    *origin - <origin> block for the base-to-parent joint
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="aubo_i5" params="parent prefix *origin">

    <!-- Base attachment joint -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child  link="${prefix}base_link"/>
    </joint>

    <!-- ==================== Links ==================== -->
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0.000129 0.001249 0.016678" rpy="0 0 0"/>
        <mass value="1.53902"/>
        <inertia ixx="0.003278" ixy="-0.000001" ixz="-0.000001"
                 iyy="0.003017" iyz="-0.000048" izz="0.005841"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link0.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link0.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}shoulder_Link">
      <inertial>
        <origin xyz="-0.00001 0.001807 -0.013854" rpy="0 0 0"/>
        <mass value="4.848581"/>
        <inertia ixx="0.011842" ixy="0" ixz="0.000004"
                 iyy="0.0118" iyz="-0.000103" izz="0.008103"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link1.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link1.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}upperArm_Link">
      <inertial>
        <origin xyz="0.2040 0 0.006603" rpy="0 0 0"/>
        <mass value="10.836261"/>
        <inertia ixx="0.026024" ixy="0.00002" ixz="0"
                 iyy="0.432805" iyz="0" izz="0.425155"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link2.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link2.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}foreArm_Link">
      <inertial>
        <origin xyz="0.264626 -0.00002 0.093611" rpy="0 0 0"/>
        <mass value="2.849168"/>
        <inertia ixx="0.003634" ixy="0.000007" ixz="0.000168"
                 iyy="0.065327" iyz="0.000002" izz="0.064676"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link3.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link3.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}wrist1_Link">
      <inertial>
        <origin xyz="0.000038 0.011278 -0.001539" rpy="0 0 0"/>
        <mass value="1.628022"/>
        <inertia ixx="0.001951" ixy="0.000003" ixz="0.000001"
                 iyy="0.001154" iyz="-0.000042" izz="0.001931"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link4.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link4.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}wrist2_Link">
      <inertial>
        <origin xyz="-0.000038 -0.011278 -0.001539" rpy="0 0 0"/>
        <mass value="1.628022"/>
        <inertia ixx="0.001951" ixy="0.000003" ixz="-0.000001"
                 iyy="0.001154" iyz="0.000042" izz="0.001931"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link5.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link5.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}wrist3_Link">
      <inertial>
        <origin xyz="0.000022 0.0006 -0.017081" rpy="0 0 0"/>
        <mass value="0.1978"/>
        <inertia ixx="0.000118" ixy="0.0" ixz="0"
                 iyy="0.000112" iyz="0.000001" izz="0.000184"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/visual/link6.DAE"/>
        </geometry>
        <material name=""><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://aubo_description/meshes/aubo_i5/collision/link6.STL"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}ee_link">
      <collision>
        <geometry><box size="0.01 0.01 0.01"/></geometry>
        <origin rpy="0 0 0" xyz="-0.01 0 0"/>
      </collision>
    </link>

    <!-- ==================== Joints ==================== -->
    <joint name="${prefix}shoulder_joint" type="revolute">
      <origin xyz="0 0 0.122" rpy="0 0 3.1415926535897932384626433832795"/>
      <parent link="${prefix}base_link"/>
      <child  link="${prefix}shoulder_Link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28318530718" upper="6.28318530718" effort="133" velocity="2.5964"/>
    </joint>

    <joint name="${prefix}upperArm_joint" type="revolute">
      <origin xyz="0 0.1215 0" rpy="-1.5707963267948966192313216916398 -1.5707963267948966192313216916398 0"/>
      <parent link="${prefix}shoulder_Link"/>
      <child  link="${prefix}upperArm_Link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28318530718" upper="6.28318530718" effort="133" velocity="2.5964"/>
    </joint>

    <joint name="${prefix}foreArm_joint" type="revolute">
      <origin xyz="0.408 0 0" rpy="-3.1415926535897932384626433832795 0 0"/>
      <parent link="${prefix}upperArm_Link"/>
      <child  link="${prefix}foreArm_Link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28318530718" upper="6.28318530718" effort="133" velocity="2.5964"/>
    </joint>

    <joint name="${prefix}wrist1_joint" type="revolute">
      <origin xyz="0.376 0 0" rpy="3.1415926535897932384626433832795 0 1.5707963267948966192313216916398"/>
      <parent link="${prefix}foreArm_Link"/>
      <child  link="${prefix}wrist1_Link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28318530718" upper="6.28318530718" effort="13.5" velocity="3.1105"/>
    </joint>

    <joint name="${prefix}wrist2_joint" type="revolute">
      <origin xyz="0 0.1025 0" rpy="-1.5707963267948966192313216916398 0 0"/>
      <parent link="${prefix}wrist1_Link"/>
      <child  link="${prefix}wrist2_Link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28318530718" upper="6.28318530718" effort="13.5" velocity="3.1105"/>
    </joint>

    <joint name="${prefix}wrist3_joint" type="revolute">
      <origin xyz="0 -0.094 0" rpy="1.5707963267948966192313216916398 0 0"/>
      <parent link="${prefix}wrist2_Link"/>
      <child  link="${prefix}wrist3_Link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28318530718" upper="6.28318530718" effort="13.5" velocity="3.1105"/>
    </joint>

    <joint name="${prefix}ee_fixed_joint" type="fixed">
      <parent link="${prefix}wrist3_Link"/>
      <child  link="${prefix}ee_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 1.5707963267948966192313216916398"/>
    </joint>

  </xacro:macro>

</robot>
